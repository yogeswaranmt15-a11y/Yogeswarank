input:focus,
select:focus {
    border-color: #4e73df;
    outline: none;
}

/* Button */
button {
    width: 100%;
    padding: 10px;
    margin-top: 20px;
    background-color: #4e73df;
    color: white;
    border: none;
    border-radius: 5px;
    font-size: 15px;
    cursor: pointer;
}

button:hover {
    background-color: #2e59d9;
}
